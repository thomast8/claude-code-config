{
  "mcp-debugger": {
    "type": "stdio",
    "command": "npx",
    "args": [
      "-y",
      "@debugmcp/mcp-debugger"
    ],
    "env": {}
  },
  "azure": {
    "type": "stdio",
    "command": "npx",
    "args": [
      "-y",
      "@azure/mcp@latest",
      "server",
      "start"
    ],
    "env": {}
  }
}
